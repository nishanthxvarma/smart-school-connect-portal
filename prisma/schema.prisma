datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  ADMIN
  TEACHER
  PARENT
  STUDENT
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
}

enum NoticeCategory {
  HOLIDAY
  EXAMINATION
  PARENT_MEETING
  SCHOOL_EVENT
  EMERGENCY
}

enum ResourceCategory {
  NOTES
  PDF
  YOUTUBE
  WORKSHEET
  STUDY_MATERIAL
}

enum ComplaintCategory {
  BROKEN_BENCH
  FAN_NOT_WORKING
  WATER_PROBLEM
  WASHROOM_ISSUE
  ELECTRICAL_PROBLEM
  PLAYGROUND_ISSUE
  CLASSROOM_DAMAGE
  OTHER
}

enum ComplaintStatus {
  SUBMITTED
  UNDER_REVIEW
  IN_PROGRESS
  RESOLVED
}

enum AppointmentStatus {
  PENDING
  APPROVED
  REJECTED
  RESCHEDULED
}

enum NotificationType {
  HOMEWORK
  NOTICE
  ATTENDANCE
  EVENT
  APPOINTMENT
  COMPLAINT
}

enum AchievementCategory {
  ACADEMIC
  SPORTS
  COMPETITION
}

model User {
  id           String     @id @default(auto()) @map("_id") @db.ObjectId
  email        String     @unique
  username     String     @unique
  passwordHash String
  name         String
  role         Role
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  
  studentProfile Student?
  teacherProfile Teacher?
  parentProfile  Parent?
  
  notices      Notice[]
  events       Event[]
  complaints   Complaint[]
  notifications Notification[]
}

model Teacher {
  id               String       @id @default(auto()) @map("_id") @db.ObjectId
  userId           String       @unique @db.ObjectId
  user             User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  employeeId       String       @unique
  subjectSpecialty String
  phone            String
  
  classes          Class[]
  attendanceMarked Attendance[]
  homeworkCreated  Homework[]
  resourcesUploaded Resource[]
  appointments     Appointment[]
  marksGraded      Mark[]
}

model Parent {
  id           String       @id @default(auto()) @map("_id") @db.ObjectId
  userId       String       @unique @db.ObjectId
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  phone        String
  address      String
  
  students     Student[]
  appointments Appointment[]
}

model Student {
  id           String       @id @default(auto()) @map("_id") @db.ObjectId
  userId       String       @unique @db.ObjectId
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  rollNumber   String       @unique
  
  classId      String       @db.ObjectId
  class        Class        @relation(fields: [classId], references: [id])
  
  parentId     String?      @db.ObjectId
  parent       Parent?      @relation(fields: [parentId], references: [id])
  
  attendance   Attendance[]
  marks        Mark[]
  achievements Achievement[]
}

model Class {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  name      String    @unique
  
  teacherId String?   @db.ObjectId
  teacher   Teacher?  @relation(fields: [teacherId], references: [id])
  
  students  Student[]
  homeworks Homework[]
  resources Resource[]
}

model Attendance {
  id         String           @id @default(auto()) @map("_id") @db.ObjectId
  studentId  String           @db.ObjectId
  student    Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  date       DateTime
  status     AttendanceStatus
  remarks    String?
  
  markedById String           @db.ObjectId
  markedBy   Teacher          @relation(fields: [markedById], references: [id])
  createdAt  DateTime         @default(now())
}

model Homework {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  subject     String
  classId     String    @db.ObjectId
  class       Class     @relation(fields: [classId], references: [id], onDelete: Cascade)
  description String
  dueDate     DateTime
  resourceUrl String?
  
  createdById String    @db.ObjectId
  createdBy   Teacher   @relation(fields: [createdById], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
}

model Notice {
  id            String         @id @default(auto()) @map("_id") @db.ObjectId
  title         String
  content       String
  category      NoticeCategory
  publishDate   DateTime       @default(now())
  scheduledDate DateTime?
  isPublished   Boolean        @default(true)
  
  createdById   String         @db.ObjectId
  createdBy     User           @relation(fields: [createdById], references: [id], onDelete: Cascade)
  createdAt     DateTime       @default(now())
}

model Event {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  description String
  date        DateTime
  imageUrl    String?
  
  createdById String   @db.ObjectId
  createdBy   User     @relation(fields: [createdById], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
}

model Resource {
  id           String           @id @default(auto()) @map("_id") @db.ObjectId
  title        String
  category     ResourceCategory
  fileUrl      String?
  
  classId      String           @db.ObjectId
  class        Class            @relation(fields: [classId], references: [id], onDelete: Cascade)
  subject      String
  
  uploadedById String           @db.ObjectId
  uploadedBy   Teacher          @relation(fields: [uploadedById], references: [id], onDelete: Cascade)
  createdAt    DateTime         @default(now())
}

model Complaint {
  id          String            @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  description String
  category    ComplaintCategory
  status      ComplaintStatus   @default(SUBMITTED)
  
  reporterId  String            @db.ObjectId
  reporter    User              @relation(fields: [reporterId], references: [id], onDelete: Cascade)
  photoUrl    String?
  date        DateTime          @default(now())
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

model Appointment {
  id             String            @id @default(auto()) @map("_id") @db.ObjectId
  parentId       String            @db.ObjectId
  parent         Parent            @relation(fields: [parentId], references: [id], onDelete: Cascade)
  teacherId      String            @db.ObjectId
  teacher        Teacher           @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  purpose        String
  preferredDate  DateTime
  status         AppointmentStatus @default(PENDING)
  rescheduleDate DateTime?
  remarks        String?
  createdAt      DateTime          @default(now())
}

model Mark {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  studentId  String   @db.ObjectId
  student    Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subject    String
  examName   String
  score      Float
  maxScore   Float    @default(100)
  remarks    String?
  
  gradedById String   @db.ObjectId
  gradedBy   Teacher  @relation(fields: [gradedById], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
}

model Notification {
  id        String           @id @default(auto()) @map("_id") @db.ObjectId
  userId    String           @db.ObjectId
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  type      NotificationType
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())
}

model Achievement {
  id             String              @id @default(auto()) @map("_id") @db.ObjectId
  studentId      String              @db.ObjectId
  student        Student             @relation(fields: [studentId], references: [id], onDelete: Cascade)
  title          String
  description    String
  category       AchievementCategory
  certificateUrl String?
  dateAwarded    DateTime
}
